{
  "name": "fbi-ufo-archive-kr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FBI Vault UFO PDF 16편을 한국어로 옮긴 이북 아카이브",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "content:verify": "node scripts/verify-content.mjs",
    "content:schemas": "node scripts/verify-baseline-schemas.mjs",
    "content:images": "node scripts/sync-page-images.mjs",
    "content:index": "pagefind --site dist",
    "search:index": "pagefind --site dist",
    "pdfs:download": "node scripts/download-pdfs.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@tailwindcss/vite": "^4.1.0",
    "astro": "^5.0.0",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
