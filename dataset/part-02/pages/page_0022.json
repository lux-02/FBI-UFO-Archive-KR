      "text": "light meteors.",
      "status": "image_matched"
    },
    {
      "lineNumber": 100,
      "status": "blank"
    },
    {
      "lineNumber": 101,
      "text": "Ice crystals forming little round",
      "status": "image_matched"
    },
    {
      "lineNumber": 102,
      "text": "clouds have been suggested. But",
      "status": "image_matched"
    },
    {
      "lineNumber": 103,
      "text": "these fail to fit in most cases be-",
