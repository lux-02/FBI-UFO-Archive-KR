    },
    {
      "lineNumber": 88,
      "text": "watching distance airplanes.",
      "status": "image_matched"
    },
    {
      "lineNumber": 89,
      "status": "blank"
    },
    {
      "lineNumber": 90,
      "text": "SPEED MYSTERY",
      "status": "image_matched"
    },
    {
      "lineNumber": 91,
      "status": "blank"
    },
    {
      "lineNumber": 92,
      "text": "There is no explanation for re-",
      "status": "image_matched"
    },
    {
      "lineNumber": 93,
      "text": "ported speeds of 1,000 or more",
      "status": "image_matched"
    },
    {
      "lineNumber": 94,
      "text": "miles an hour. Meteors, although",
      "status": "image_matched"
    },
    {
      "lineNumber": 95,
      "text": "they go much faster than that,",
      "status": "image_matched"
    },
    {
      "lineNumber": 96,
      "text": "do not explain it because the",
      "status": "image_matched"
    },
    {
      "lineNumber": 97,
      "text": "saucers mostly appear in daytime",
      "status": "image_matched"
    },
    {
      "lineNumber": 98,
      "text": "and there are not enough day-",
      "status": "image_matched"
    },
    {
