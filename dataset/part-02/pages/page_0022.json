    },
    {
      "lineNumber": 105,
      "text": "altitudes which are higher than",
      "status": "image_matched"
    },
    {
      "lineNumber": 106,
      "text": "most of the saucers reported.",
      "status": "image_matched"
    },
    {
      "lineNumber": 107,
      "status": "blank"
    },
    {
      "lineNumber": 108,
      "text": "Nothing published in science or",
      "status": "image_matched"
    },
    {
      "lineNumber": 109,
      "text": "atomic studies gives the slightest",
      "status": "image_matched"
    },
    {
      "lineNumber": 110,
      "text": "clue to flying saucers unless the",
      "status": "image_matched"
    },
    {
      "lineNumber": 111,
      "text": "objects are aircraft.",
      "status": "image_matched"
    },
    {
      "lineNumber": 112,
      "status": "blank"
    },
    {
      "lineNumber": 113,
      "text": "One scientist today said that at",
      "status": "image_matched"
    },
    {
      "lineNumber": 114,
      "text": "least a lot of saucers are ex-",
      "status": "image_matched"
    },
    {
