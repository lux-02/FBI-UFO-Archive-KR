      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "Sunday.",
      "status": "image_matched"
    },
    {
      "lineNumber": 21,
      "text": "She said they were driving on a",
      "status": "image_matched"
    },
    {
