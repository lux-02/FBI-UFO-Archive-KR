    },
    {
      "lineNumber": 101,
      "text": "bles what can be seen while",
      "status": "image_matched"
    },
    {
      "lineNumber": 102,
      "text": "watching distant airplanes.",
      "status": "image_matched"
    },
    {
      "lineNumber": 103,
      "text": "Whether planes are guided, pi-",
      "status": "image_matched"
    },
    {
      "lineNumber": 104,
      "text": "lotless or jet, they all would look",
      "status": "image_matched"
    },
    {
