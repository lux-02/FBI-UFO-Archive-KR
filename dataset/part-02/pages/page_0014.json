    },
    {
      "lineNumber": 29,
      "text": "the sun.\"",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "status": "blank"
    },
    {
      "lineNumber": 31,
      "text": "Stops Car, Disk Vanishes",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "status": "blank"
    },
    {
