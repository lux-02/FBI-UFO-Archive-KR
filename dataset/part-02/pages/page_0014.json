      "text": "12:15 a.m. Sunday.",
      "status": "image_matched"
    },
    {
      "lineNumber": 16,
      "text": "At Oshkosh, Mrs. L. A. Davis re-",
      "status": "image_matched"
    },
    {
      "lineNumber": 17,
      "text": "ported that she and her husband had",
      "status": "image_matched"
