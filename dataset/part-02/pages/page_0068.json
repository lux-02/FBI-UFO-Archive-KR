      "lineNumber": 9,
      "text": "To: Commanding Officer, Alaska Communication System",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 10,
      "text": "550 Federal Office Building, Seattle 4, Washington",
