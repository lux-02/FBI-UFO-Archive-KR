    {
      "lineNumber": 9,
      "text": "RE: CIVILIAN RESEARCH, INTERPLANETARY",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 10,
      "text": "FLYING OBJECTS, LEONARD H. STRINGFIELD,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 11,
