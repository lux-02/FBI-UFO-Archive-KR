    {
      "lineNumber": 8,
      "status": "blank"
    },
    {
      "lineNumber": 9,
      "text": "Dear Sir:",
      "status": "image_matched"
    },
    {
      "lineNumber": 10,
      "status": "blank"
    },
    {
      "lineNumber": 11,
      "text": "It is the responsibility of the Air Force's Project",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "text": "Blue Book to investigate and analyze UFO sightings. At times",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "local or state law enforcement officials have been requested",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "to make investigations of such cases.",
      "status": "image_matched"
    },
    {
      "lineNumber": 15,
      "status": "blank"
    },
    {
      "lineNumber": 16,
      "text": "After a number of recent sightings in Rehoboth, Mass.,",
      "status": "image_matched"
