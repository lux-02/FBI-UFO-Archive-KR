    {
      "lineNumber": 9,
      "text": "Dear Mr. [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 10,
      "status": "blank"
    },
    {
      "lineNumber": 11,
      "text": "I received your letter on July 15th, with enclosure, which is being returned herewith.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 12,
      "status": "blank"
    },
    {
      "lineNumber": 13,
      "text": "For your information, the investigation of Unidentified Flying Objects is not and never has been a matter that is within the investigative jurisdiction of the FBI. I can assure you the photograph which you forwarded does not represent employees of this Bureau and the FBI has never had custody of an occupant from a foreign planet.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 14,
      "status": "blank"
    },
    {
      "lineNumber": 15,
      "text": "MAILED 4",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 16,
      "text": "JUL 21 1966",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 17,
      "text": "COMM-FBI",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 18,
      "status": "blank"
    },
    {
      "lineNumber": 19,
      "text": "Sincerely yours,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 20,
      "text": "J. Edgar Hoover",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 21,
      "status": "blank"
    },
    {
      "lineNumber": 22,
      "text": "Enclosure",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 23,
      "text": "NOTE: Correspondent is not identifiable in Bufiles. Enclosure was a photograph of an apparently emaciated child holding the hand of two male adults. Relations with \"Real\" magazine have not been desirable. The article which appeared in a recent issue of this magazine purported to be an actual report of unidentified flying objects and has been brought to the attention of the Bureau previously. In view of the fictional aspects of the article and the relations with \"Real\" magazine no contact was made with the magazine regarding the representation of FBI Agents.",
      "status": "pending_image_audit"
    },
