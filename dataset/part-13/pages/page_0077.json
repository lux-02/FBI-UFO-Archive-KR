      "lineNumber": 11,
      "text": "Dear Mr. Hoover,",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "status": "blank"
    },
    {
      "lineNumber": 13,
      "text": "Just recently I bought a copy of the magazine, \"Real.\"",
      "status": "image_matched"
