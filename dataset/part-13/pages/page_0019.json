      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "status": "blank"
    },
    {
      "lineNumber": 37,
      "text": "Per call to the Library of Congress \"Aboard a Flying",
      "status": "image_matched"
    },
    {
      "lineNumber": 38,
      "text": "Saucer\" was written by Truman/Bethurum. In June, 1954, an",
      "status": "pending_image_audit"
