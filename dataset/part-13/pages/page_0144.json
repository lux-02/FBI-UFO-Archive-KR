    },
    {
      "lineNumber": 17,
      "status": "blank"
    },
    {
      "lineNumber": 18,
      "text": "On the basis of information furnished by him, it is not possible",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 19,
      "text": "to identify the \"[REDACTED]\" he is referring to in his correspondence. The",
      "status": "redaction_marker_check"
    },
