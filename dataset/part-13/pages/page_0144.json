    {
      "lineNumber": 14,
      "text": "Enclosed are copies of a letter dated October 10, 1960, which",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 15,
      "text": "was received from captioned individual and my reply to him, all of which are",
      "status": "pending_image_audit"
    },
    {
