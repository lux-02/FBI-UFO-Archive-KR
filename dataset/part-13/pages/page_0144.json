      "lineNumber": 20,
      "text": "possibility exists that he may be identical with [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 21,
      "text": "[REDACTED] Glendale, New York. Since",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 22,
      "text": "October, 1957, the Bureau has received several communications from [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 23,
      "text": "on the letterhead of the [REDACTED] of which he was listed",
      "status": "redaction_marker_check"
