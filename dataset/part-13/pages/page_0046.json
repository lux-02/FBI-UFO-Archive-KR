      "text": "Lebanon and the French Cameroons.",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "status": "blank"
    },
    {
      "lineNumber": 19,
      "text": "LATEST DISCS cited here were Monday at",
      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "3 p. m. by WLW announcer Keith Wildeson.",
      "status": "image_matched"
    },
    {
