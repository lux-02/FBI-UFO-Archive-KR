      "text": "ter,\" were reported hovering 300 feet over Cin-",
      "status": "image_matched"
    },
    {
      "lineNumber": 8,
      "text": "cinnati Monday.",
      "status": "image_matched"
    },
    {
      "lineNumber": 9,
      "status": "blank"
    },
    {
      "lineNumber": 10,
      "text": "This was the fifth report within a week of",
      "status": "image_matched"
    },
    {
      "lineNumber": 11,
      "text": "similar objects seen around the city, always",
      "status": "image_matched"
