      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "status": "blank"
    },
    {
      "lineNumber": 14,
      "text": "A similar wave of flying saucer reports has",
      "status": "image_matched"
    },
    {
      "lineNumber": 15,
      "text": "cropped up in five other parts of the world,",
      "status": "image_matched"
    },
    {
      "lineNumber": 16,
      "text": "including Germany, Belgium, Egypt, Argentina,",
      "status": "image_matched"
    },
    {
