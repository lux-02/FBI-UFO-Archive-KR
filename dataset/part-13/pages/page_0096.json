      "text": "stated that the FBI was investigating this sighting.",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "status": "blank"
    },
    {
      "lineNumber": 33,
      "text": "Would it be possible to obtain the results of your invest-",
      "status": "image_matched"
