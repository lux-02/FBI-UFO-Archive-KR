      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "status": "blank"
    },
    {
      "lineNumber": 23,
      "text": "I have received special authorization from the Department",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "of the Air Force in Washington to visit Wright Patterson",
      "status": "image_matched"
    },
