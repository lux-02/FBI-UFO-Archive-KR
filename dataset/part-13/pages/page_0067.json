      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 9,
      "text": "Milford, Ohio. Mr. [REDACTED] said that he could be",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
