    {
      "lineNumber": 21,
      "text": "DIRECTOR FBI",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "FLYING DISC FOUND AT ALICE, TEXAS, JULY FOUR, FIFTY, INTERNAL SECURITY",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "DASH, R. CAA REPRESENTATIVES SAN ANTONIO, ADVISED THIS OFFICE AT TWELVE",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "FIFTEEN P. M. THIS DATE THAT THEY HAD RECEIVED INFORMATION FROM THEIR",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "REPRESENTATIVE AT ALICE THAT A FLYING DISC HAD BEEN FOUND BETWEEN THE",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "MUNICIPAL AIRPORT AND THE CITY OF ALICE. DISC IS ELLIPITICAL SHAPE,",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "FOUR TO FIVE FEET IN DIAMETER, HAS TWO RADIO AERIALS, SLOTS OR HOLES",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "INDICATING JET OR ROCKET PROPULSION. DISC HAS NO. X ONE FOUR SEVEN A",
      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "text": "PRINTED ON IT, TOGETHER WITH QUOTE DO NOT TOUCH UNQUOTE. LOCAL RADIO",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "NEWSCAST QUOTES CHIEF OF POLICE, ALICE, TEXAS AS STATING FLYING",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "DISC A HOAX. OSI, KELLY AFB AND HOUSTON OFFICE ADVISED.",
      "status": "image_matched"
    },
