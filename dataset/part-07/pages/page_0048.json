    {
      "lineNumber": 18,
      "status": "blank"
    },
    {
      "lineNumber": 19,
      "text": "TO: Director of Special Investigations",
      "status": "correction_required"
    },
    {
      "lineNumber": 20,
      "text": "Headquarters, United States Air Force",
      "status": "image_matched"
