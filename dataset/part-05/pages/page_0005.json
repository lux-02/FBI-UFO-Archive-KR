    {
      "lineNumber": 11,
      "status": "blank"
    },
    {
      "lineNumber": 12,
      "text": "This is my own written statement of what I saw on July 8, 1947.",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "status": "blank"
    },
    {
      "lineNumber": 14,
      "text": "I am NCO in charge of the [REDACTED] this Field, and",
