      "text": "O.N.I.-S.I.D.-F.B.I. Intelligence conference that the Public Relations Officer b7c",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 26,
      "text": "at McChord Field had received a telephone call from an individual at Army Air",
      "status": "image_matched"
    },
    {
