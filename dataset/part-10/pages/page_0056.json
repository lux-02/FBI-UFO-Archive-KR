      "status": "pending_image_audit"
    },
    {
      "lineNumber": 12,
      "text": "RADAR DETECTION OF UNIDENTIFIED OBJECTS OVER OAK RIDGE OCTOBER TWELVE,",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "NINETEEN FIFTY, PROTECTION OF VITAL INSTALLATIONS. USAF RADAR INSTALL-",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 14,
      "text": "ATION AT KNOXVILLE AT ELEVEN TWENTYFIVE PM, EST, OCTOBER TWELVE, PICKED",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 15,
      "text": "UP INDICATIONS OF ELEVEN OBJECTS AND PERHAPS MORE TRAVELING ACROSS",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 16,
      "text": "CONTROLLED AREA OF ATOMIC ENERGY INSTALLATION AT OAK RIDGE. ALTITUDE",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 17,
      "text": "OF OBJECTS VARIED FROM ONE THOUSAND TO FIVE THOUSAND FEET, COURSES",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 18,
      "text": "FROM SOUTH SOUTH EAST TO SOUTHEAST, AND DENSITY FROM READING MADE BY",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 19,
      "text": "LIGHT AIRCRAFT TO AIRCRAFT EQUAL IN SIZE TO C FORTY SEVEN, SPEED",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 20,
      "text": "FROM ONE HUNDRED TO ONE HUNDRED TWENTYFIVE MILES PER HOUR. FIGHTER",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 21,
      "text": "PLANE ATTEMPTED TO INTERCEPT IN FEW MINUTES AND RADAR SCREEN REFLECTED",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 22,
      "text": "CONTACT, BUT PLANE REPORTED NO OBJECT COULD BE SEEN EITHER VISUALLY",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 23,
      "text": "OR ON PLANES RADAR SCREEN. AEC PATROL WAS ALERTED BUT NO OBJECTS COULD",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 24,
      "text": "BE VISUALLY SIGHTED BY THEM OVER THE AREA OTHER THAN THE AIR",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 25,
      "text": "FORCE INTERCEPTOR. OSI AND EASTERN AIR DEFENSE FORCES HAVE BEEN",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 26,
      "text": "ADVISED AND ARE CHECKING INCIDENT. NO REASONABLE EXPLANATION FOR",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 27,
      "text": "RADAR READINGS YET DEVELOPED ALTHOUGH OPERATORS ARE EXPERIENCED",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 28,
      "text": "RELIABLE PERSONNEL AND RADAR SET IS IN PERFECT OPERATING CONDITION.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 29,
      "text": "BUREAU WILL BE ADVISED OF FURTHER DEVELOPMENTS.",
      "status": "pending_image_audit"
