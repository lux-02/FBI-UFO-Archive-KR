    },
    {
      "lineNumber": 10,
      "status": "blank"
    },
    {
      "lineNumber": 11,
      "text": "were riding in the front",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "text": "seat;",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
