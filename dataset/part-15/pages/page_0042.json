    },
    {
      "lineNumber": 25,
      "text": "SAUCER WOULD LAND ON EARTH.",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "CONDON, PROFESSOR OF PHYSICS AT THE UNIVERSITY OF COLORADO, SAID",
