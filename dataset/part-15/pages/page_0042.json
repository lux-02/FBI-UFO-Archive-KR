    },
    {
      "lineNumber": 22,
      "text": "BOULDER, COLO.--DR. EDWARD CONDON, HEAD OF A GOVERNMENT-",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "FINANCED SCIENTIFIC STUDY OF UNIDENTIFIED FLYING OBJECTS (UFO), SAID",
      "status": "image_matched"
    },
    {
