      "text": "officer who uses the alias of [REDACTED] concerning unidentified flying",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 25,
      "text": "objects and that it is the TV producer's intention to use this individual",
      "status": "image_matched"
    },
