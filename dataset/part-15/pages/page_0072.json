    },
    {
      "lineNumber": 112,
      "text": "sesses evidence of such vehicles operating",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 113,
      "text": "in our atmosphere.\" And he states: \"No UFO",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 114,
      "text": "report evaluated by the Air Force has ever",
