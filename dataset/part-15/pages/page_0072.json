      "lineNumber": 169,
      "text": "names used but still want to tell somebody",
      "status": "image_matched"
    },
    {
      "lineNumber": 170,
      "text": "what they've seen, claims J. B. Hartanft, Jr.,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 171,
      "text": "president of the Aircraft Owners and Pilots As-",
      "status": "image_matched"
    },
    {
