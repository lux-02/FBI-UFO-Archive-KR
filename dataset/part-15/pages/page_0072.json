    },
    {
      "lineNumber": 144,
      "text": "cago.",
      "status": "image_matched"
    },
    {
      "lineNumber": 145,
      "text": "\"The possibility of life on Mars is an un-",
      "status": "image_matched"
    },
    {
      "lineNumber": 146,
      "text": "popular thing to consider these days,\" says",
      "status": "pending_image_audit"
