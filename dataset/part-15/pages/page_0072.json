    },
    {
      "lineNumber": 115,
      "text": "given any indication of a threat to our national",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 116,
      "text": "security.\"",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 117,
      "text": "The Air Force's approach disturbs some",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 118,
      "text": "people, however. \"The Air Force should admit",
      "status": "image_matched"
    },
    {
      "lineNumber": 119,
