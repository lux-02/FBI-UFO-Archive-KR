      "status": "pending_image_audit"
    },
    {
      "lineNumber": 70,
      "text": "Lancs, Pc. Cameron said:",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 71,
      "text": "\"I suppose I will get",
      "status": "pending_image_audit"
    },
