    {
      "lineNumber": 13,
      "text": "At 4:10 a.m., January 18, 1967, [REDACTED] advised",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 14,
      "text": "that he desired to report that he had observed a large",
      "status": "image_matched"
    },
