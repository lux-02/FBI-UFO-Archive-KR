      "status": "pending_image_audit"
    },
    {
      "lineNumber": 8,
      "status": "blank"
    },
    {
      "lineNumber": 9,
      "text": "He also wanted to tell me something. About a",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 10,
      "text": "young lady of rather special appearance who had,",
      "status": "pending_image_audit"
