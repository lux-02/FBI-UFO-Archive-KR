      "status": "pending_image_audit"
    },
    {
      "lineNumber": 69,
      "text": "any excusable source.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 70,
      "status": "blank"
    },
    {
      "lineNumber": 71,
      "text": "I would be willing indeed to show this rare film",
      "status": "image_matched"
    },
    {
      "lineNumber": 72,
      "text": "personally) to Air Force officials here in Washing-",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 73,
      "text": "ton D.C., if they are interested.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 74,
      "status": "blank"
    },
    {
      "lineNumber": 75,
      "text": "Any Monday would be fine for showing the film,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 76,
      "text": "I am looking forward to your answer,",
      "status": "image_matched"
    },
    {
