      "status": "image_matched"
    },
    {
      "lineNumber": 47,
      "status": "blank"
    },
    {
      "lineNumber": 48,
      "text": "A letter from Fred to Thomas G. Corbin, Major-",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 49,
      "text": "General U.S.A.F. Director Legislative Liaison, Dep-",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 50,
      "text": "artment of the Air Force, Washington, D.C., read:",
      "status": "image_matched"
    },
    {
      "lineNumber": 51,
      "status": "blank"
    },
    {
      "lineNumber": 52,
      "text": "\"Dear Sir,",
      "status": "image_matched"
    },
    {
      "lineNumber": 53,
      "status": "blank"
    },
    {
      "lineNumber": 54,
      "text": "While with my family in Germany September 7,",
      "status": "pending_image_audit"
    },
