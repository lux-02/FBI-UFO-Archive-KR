      "status": "blank"
    },
    {
      "lineNumber": 3,
      "text": "\"THE OREGONIAN\" Portland, Oregon.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 4,
      "text": "3 July 1947",
      "status": "permanent_unresolved",
