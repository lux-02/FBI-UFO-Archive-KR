    },
    {
      "lineNumber": 4,
      "text": "TO : D.M.LADD DATE: July 7, 1947",
      "status": "image_matched"
    },
    {
      "lineNumber": 5,
      "text": "9:50 PM",
      "status": "image_matched"
    },
    {
      "lineNumber": 6,
