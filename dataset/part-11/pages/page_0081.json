    },
    {
      "lineNumber": 16,
      "text": "President of the [REDACTED] in Cincinnati. Mr. [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 17,
      "text": "did all the talking for the two men and he furnished the following informa-",
