      "status": "pending_image_audit"
    },
    {
      "lineNumber": 17,
      "text": "or someone that a person could call",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 18,
      "text": "to report such findings. I would appreciate",
      "status": "pending_image_audit"
