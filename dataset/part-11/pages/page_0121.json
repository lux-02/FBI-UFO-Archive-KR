    },
    {
      "lineNumber": 7,
      "status": "blank"
    },
    {
      "lineNumber": 8,
      "text": "[REDACTED] called from Bowie, Maryland, at",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 9,
      "text": "9:05 P.M., 3/9/53, to advise that he had just seen a",
      "status": "image_matched"
    },
    {
      "lineNumber": 10,
      "text": "flying saucer near that city. He was vague as to",
      "status": "image_matched"
