      "text": "contained in your letter available to me.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 11,
      "status": "blank"
    },
    {
      "lineNumber": 12,
      "text": "Inasmuch as the information contained in your",
      "status": "pending_image_audit"
    },
