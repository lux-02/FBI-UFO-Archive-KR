    },
    {
      "lineNumber": 5,
      "text": "MISCELLANEOUS - INFORMATION CONCERNING",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 6,
      "text": "(ESPIOMAGE)",
