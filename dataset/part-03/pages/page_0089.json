      "text": "1. Attached hereto:",
      "status": "image_matched"
    },
    {
      "lineNumber": 9,
      "text": "a. Copy of unsigned telegram received by HQ AAF 9 July 1947, in which it is indicated that [REDACTED] Illinois may have information concerning the origin of the \"flying saucers\".",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 10,
      "text": "b. Copy of a report on flying saucers which were observed by four witnesses while in flight in two airplanes over southern Wisconsin.",
      "status": "image_matched"
    },
    {
      "lineNumber": 11,
      "text": "c. Map with indications as to proximity of the locations where the flying saucers were reported to have been seen in relation to [REDACTED], Ill.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 12,
      "text": "that the time",
      "status": "image_matched"
