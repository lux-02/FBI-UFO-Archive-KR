    {
      "lineNumber": 29,
      "text": "FLYING DISCS, S. M. - X. RETEL PORTLAND TO DIRECTOR, SAN FRANCISCO,",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "AND SEATTLE AUGUST FIVE LAST. INTELLIGENCE OFFICERS MCCORD FIELD,",
