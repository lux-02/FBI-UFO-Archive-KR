    },
    {
      "lineNumber": 31,
      "text": "WN., ADVISE THAT IN THEIR [unclear] OPINION AND FROM THEIR INVESTIGATION",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 32,
      "text": "THERE IS NO QUESTION OF THE CRASH OF THE B- TWENTYFIVE AT KELSO, WN.",
      "status": "image_matched"
    },
