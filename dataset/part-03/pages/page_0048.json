    {
      "lineNumber": 10,
      "text": "Reference is made to my memorandum to you in the above captioned",
      "status": "image_matched"
    },
    {
      "lineNumber": 11,
      "text": "matter dated August 22, 1947, which indicated that Special Agent [REDACTED]",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 12,
      "text": "of the Liaison Section had contacted Lieutenant Colonel [REDACTED]",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 13,
      "text": "of the Air Forces Intelligence at which time Colonel Garrett advised that",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "the Army Air Forces were conducting no research or experiments in the",
      "status": "image_matched"
    },
