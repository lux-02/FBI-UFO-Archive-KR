    {
      "lineNumber": 16,
      "status": "blank"
    },
    {
      "lineNumber": 17,
      "text": "[REDACTED] was interviewed and described the object which she b7c",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 18,
      "text": "has observed as follows:",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "status": "blank"
    },
    {
      "lineNumber": 20,
      "text": "While entertaining her 7 year old son and 10 year old neighbor",
      "status": "image_matched"
    },
    {
      "lineNumber": 21,
      "text": "child on her lawn, at about noon, [REDACTED] and the children noticed",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 22,
      "text": "approximately two dozen round silver objects high in the sky.",
      "status": "image_matched"
    },
    {
