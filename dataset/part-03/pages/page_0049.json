    {
      "lineNumber": 13,
      "text": "Reference is made to my teletype dated 9-4-47, advising that",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "Mrs. [REDACTED] Oswego, Oregon, was reported to have seen a number b7c",
