    {
      "lineNumber": 11,
      "text": "SUBJECT: FLYING DISCS",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "status": "blank"
    },
    {
      "lineNumber": 13,
      "text": "Reference is made to my letter to the Bureau dated July 28, 1947 entitled as above forwarding a copy of a report furnished to me by Lieutenant [REDACTED] Fourth Air Force, Hamilton Field, California, setting forth the results of inquiries made by his office concerning the reported sightings of flying discs.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 14,
      "status": "blank"
    },
    {
      "lineNumber": 15,
      "text": "As of further interest to the Bureau in this regard, there is transmitted herewith photostatic copies of three letters dated August 4, 1947 and entitled \"Investigation of Flying Discs,\" furnished to me by [REDACTED] S, A-2, Army Air Forces, Hamilton Field, California, who is acting in the absence of [REDACTED] enclosing copies of reports of additional reported sightings of flying discs by persons in Oregon and Arizona, together with the results of their investigations in that regard.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 16,
      "status": "blank"
    },
    {
      "lineNumber": 17,
      "text": "It is noted that these investigations were conducted prior to the time Bureau instructions were issued that our own Bureau would conduct inquiries into the reported sightings of flying discs.",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "status": "blank"
    },
    {
      "lineNumber": 19,
      "text": "Copies of these reports are being forwarded to the Portland and Phoenix Offices for the completion of their files in connection with this subject.",
      "status": "image_matched"
