    {
      "lineNumber": 13,
      "text": "Mr. [REDACTED] on 12/20/57 advised",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 14,
      "text": "the Resident Agent at Hannibal that he was in receipt",
