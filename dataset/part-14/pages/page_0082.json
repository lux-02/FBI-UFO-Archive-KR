      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "\"To All Concerned:",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "status": "blank"
    },
    {
      "lineNumber": 29,
      "text": "\"If anyone has seen any unidentified flying objects--",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "known also as flying saucers--or knows anyone who has",
      "status": "image_matched"
    },
    {
