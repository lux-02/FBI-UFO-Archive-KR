    },
    {
      "lineNumber": 20,
      "status": "blank"
    },
    {
      "lineNumber": 21,
      "text": "URGENT 3-9-60 4-31PM ALF",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "TO DIRECTOR, FBI",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "FROM SAC DETROIT 165-2677/ 2P",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "UNIDENTIFIED FLYING OBJECT., JOSEPH PERRY, GRAND BLANC, MICHIGAN -",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "COMPLAINANT. FOLLOWING BEING SUBMITTED BUREAU IN VIEW OF ARTICLES",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "APPEARING DETROIT TIMES TODAY, DATELINE GRAND BLANC, MICHIGAN,",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "REFLECTING THE FBI FLINT RESIDENT AGENCY WAS FURNISHED SLIDES OF",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "PHOTOGRAPHS TAKEN BY JOSEPH PERRY ALLEGEDLY SHOWING A SAUCER-LIKE",
      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "text": "OBJECT SILHOUETTED AGAINST THE MOON. ARTICLE INDICATES FBI IS",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "INTERESTED IN THE PICTURE. JOSEPH PERRY, THREE NAUGHT SEVEN NINE",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "EDWARDS STREET, GRAND BLANC, MICHIGAN, ON MARCH FOUR LAST",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "text": "TELEPHONICALLY CALLED THE FLINT RESIDENT AGENCY AND ADVISED AGENTS",
      "status": "image_matched"
    },
    {
      "lineNumber": 33,
      "text": "HE HAS BEEN A PROFESSIONAL PHOTOGRAPHER THE PAST THIRTY YEARS. HE",
      "status": "image_matched"
    },
    {
      "lineNumber": 34,
      "text": "HAS A HOBBY OF TAKING PHOTOGRAPHS OF THE MOON THROUGH A HOMEMADE",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "TELESCOPE, AND AT ABOUT ONE A.M., FEBRUARY TWENTYONE LAST, TOOK",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "PHOTOGRAPHS OF THE MOON, AND AFTER DEVELOPING SAME NOTED IN ONE",
      "status": "image_matched"
    },
    {
      "lineNumber": 37,
      "text": "WHAT APPEARED TO BE A FLYING OBJECT. CUSTOMERS OF HIS PIZZA PIE",
      "status": "image_matched"
    },
    {
      "lineNumber": 38,
      "text": "RESTAURANT SUGGESTED THE PHOTOGRAPH MAY REFLECT FLYING SAUCER.",
      "status": "image_matched"
    },
    {
      "lineNumber": 39,
      "text": "INFORMATION FURNISHED PRESS BY JOE PERRY REFERRED TO ABOVE. FLINT",
      "status": "image_matched"
    },
    {
      "lineNumber": 40,
      "text": "END PAGE ONE",
      "status": "image_matched"
    },
