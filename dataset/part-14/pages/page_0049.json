      "status": "blank"
    },
    {
      "lineNumber": 40,
      "text": "\"Dear Mr. [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 41,
      "status": "blank"
    },
    {
      "lineNumber": 42,
      "text": "\"You have often wondered where the 3 men came",
      "status": "image_matched"
    },
    {
