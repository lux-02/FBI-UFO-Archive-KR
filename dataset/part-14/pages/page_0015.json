    {
      "lineNumber": 23,
      "status": "blank"
    },
    {
      "lineNumber": 24,
      "text": "Reference is made to this Bureau's memorandum",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "dated March 9, 1960, at Detroit, Michigan, captioned as",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
