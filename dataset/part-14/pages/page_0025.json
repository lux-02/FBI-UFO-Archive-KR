      "text": "SUBJECT: UNIDENTIFIED FLYING OBJECT;",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 16,
      "text": "JOSEPH PERRY, Grand Blanc, Michigan- Flying Saucers",
