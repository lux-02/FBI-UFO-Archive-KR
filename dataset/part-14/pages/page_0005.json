      "status": "image_matched"
    },
    {
      "lineNumber": 5,
      "text": "Denver, Colorado",
      "status": "image_matched"
    },
    {
      "lineNumber": 6,
      "text": "April 26, 1960",
      "status": "image_matched"
    },
    {
      "lineNumber": 7,
      "status": "blank"
    },
    {
      "lineNumber": 8,
      "text": "Re: [REDACTED]",
      "status": "permanent_unresolved",
