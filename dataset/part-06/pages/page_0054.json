    {
      "lineNumber": 12,
      "text": "FLYING DISCS. INFORMATION RECEIVED AT LOGAN, UTAH ELEVEN AM TODAY",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "THAT AT NINE AM A GUARD AT THE ARMY GENERAL SUPPLY DEPOT, OGDEN, UTAH,",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "OBSERVED WHAT APPEARED TO BE AN EXPLOSION IN THE AIR ACCOMPANIED BY",
      "status": "image_matched"
    },
    {
      "lineNumber": 15,
      "text": "A FLASH OF LIGHT FOLLOWED BY THE FALLING OF SILVER COLORED OBJECT.",
      "status": "image_matched"
    },
    {
      "lineNumber": 16,
      "text": "THIS WAS SEEN AT HIGH ALTITUDE WEST OF OGDEN NEAR THE TOWN OF TAYLOR,",
      "status": "image_matched"
    },
    {
      "lineNumber": 17,
      "text": "UTAH. ABOUT THE SAME TIME LT. [REDACTED] OF LOGAN, UTAH PD SAW TWO",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 18,
      "text": "PUFFS OF SMOKE HIGH IN THE AIR WEST OF LOGAN FOLLOWED BY FALLING OF 67C",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "text": "SILVER COLORED OBJECT. ALSO AT ABOUT SAME TIME UTAH HIGHWAY PATROLMAN",
      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "[REDACTED] AT MANTUA, UTAH, SAW A SILVER COLORED OBJECT HIGH UP",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 21,
      "text": "APPROACHING THE MOUNTAINS AT SARDINE CANYON BETWEEN LOGAN AND BRIGHAM",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "CITY, UTAH AND AS OBJECT NEARED THE MOUNTAIN IT APPEARED TO EXPLODE IN A",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "FLASH OF FIRE. SEVERAL RESIDENTS AT TRENTON, UTAH, WHICH IS WEST OF",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "LOGAN, HAVE REPORTED TO SO, LOGAN, SEEING WHAT APPEARED TO BE TWO AERIAL",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "EXPLOSIONS FOLLOWED BY FALLING OBJECT WEST OF TRENTON AT ABOUT NINE",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "TWENTY AM TODAY. ABOVE INFORMATION IMMEDIATELY FURNISHED TO OSI,",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "HILL FIELD, UTAH. ANY FURTHER PERTINENT DEVELOPMENTS WILL BE FURNISHED",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "BUREAU FOR INFORMATION. OSI HILL FIELD HAS JUST NOW ADVISED ABOVE",
      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "text": "PHENOMENA PROBABLY CAUSED BY TWO B TWENTYNINES FROM WENDOVER FIELD",
      "status": "image_matched"
    },
    {
