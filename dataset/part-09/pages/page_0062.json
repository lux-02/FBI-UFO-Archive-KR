      "text": "RECORDED 62-83894-281",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 48,
      "status": "blank"
    },
    {
      "lineNumber": 49,
      "text": "By letter dated September 4, 1947, the Phoenix Office",
      "status": "image_matched"
    },
    {
      "lineNumber": 50,
      "text": "set forth in four pages the results of this interview and stated",
      "status": "image_matched"
    },
    {
