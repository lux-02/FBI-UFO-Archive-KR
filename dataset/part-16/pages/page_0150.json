      "lineNumber": 3,
      "text": "the B36, has a wingspan of 240 feet, and the fastest aircraft, the",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 4,
      "text": "X1 Bell rocket plane, Douglas 558-2, the X34 Douglas Rocket plane each",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
