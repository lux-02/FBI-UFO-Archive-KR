      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "status": "blank"
    },
    {
      "lineNumber": 30,
      "text": "The only information that could be obtained from",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "[REDACTED] was that a [REDACTED], associated with the",
      "status": "redaction_marker_check"
