      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 6,
      "status": "blank"
    },
    {
      "lineNumber": 7,
      "text": "JULY 6, 1951 8:25 - 8:29 AM. LYNCHBURG, Virginia. 37½° Lat, 79° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 8,
      "text": "Sky Clear. A bright orange disc-like object hovered",
      "status": "image_matched"
    },
    {
      "lineNumber": 9,
      "text": "high in sky, suddenly zigzagged about, then appeared to",
      "status": "image_matched"
    },
    {
      "lineNumber": 10,
      "text": "roll on edge as it moved westward in a straight course",
      "status": "image_matched"
    },
    {
      "lineNumber": 11,
      "text": "without any visible exhaust and audible sound.",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "text": "#16",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "SOURCE: LYNCHBURG NEWS SEPT 28, personal letter.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 14,
      "status": "blank"
    },
    {
      "lineNumber": 15,
      "text": "JULY 7, 1951 Evening. LOS ANGELES, California. 34° Lat, 118½° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 16,
      "text": "Brilliant motionless light hovered high in sky. Later",
      "status": "image_matched"
    },
    {
      "lineNumber": 17,
      "text": "a pale circular disc appeared under it, and then both",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "text": "objects suddenly moved southwards, with disc leading.",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "text": "Then extreme sharp reflection, and light now lead disc.",
      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "Then the light blinked on and off 4-5 times, went out,",
      "status": "image_matched"
    },
    {
      "lineNumber": 21,
      "text": "and disc sped away at great speed.",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "#17",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "SOURCE: FATE MAGAZINE NOV 1951 letter section.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 24,
      "status": "blank"
    },
    {
