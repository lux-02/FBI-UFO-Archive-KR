      "lineNumber": 1,
      "text": "JUNE 29 1951? Daytime? TE THOUSAND ISLAND area, FLORIDA. 26° Lat, [unclear]",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 2,
      "text": "Object resembling a small plane fell into sea. No known",
      "status": "image_matched"
    },
    {
      "lineNumber": 3,
      "text": "aircraft missing, and widespread search found nothing.",
      "status": "image_matched"
    },
    {
