  "lines": [
    {
      "lineNumber": 1,
      "text": "OCT. 2, 1951 11:00 PM. FOGANSBURG, N.Y. 45° Lat, 74° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 2,
      "text": "A 4 foot dark brown, rubber-like ball, with a 2 foot brass",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 3,
      "text": "shaft, and a propellor on top of shaft, landed with a",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 4,
      "text": "humming noise in a pasture. It was later seen 400 feet in",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 5,
      "text": "the air, came down vertically, bounced 3 times, and landed",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 6,
      "text": "for 4 minutes. It then took off at 25 mph toward Massena,",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 7,
      "text": "NY and was followed by 4 people in a truck. Washington Air",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 8,
      "text": "Force spokesman and nearby colleges using meteorological",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 9,
      "text": "balloons stated they had nothing resembling this object.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 10,
      "text": "#34 SOURCES: NY World Telegram & Sun Oct 3; Massena Observer Oct",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 11,
      "text": "OCT. 2, 1951 Evening. EASTERN Denmark. 56° Lat., 9° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 12,
      "text": "Giant rocket travelling at great speed crossed sky coming",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "from direction of Germany.",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "#35 SOURCE: Brooklyn Eagle Oct 3",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 15,
      "text": "OCT 3, 1951 Afternoon. Near Massena, NY. 45° Lat., 74° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 16,
      "text": "The same 4 foot brown ball landed along the Scheil Channel",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 17,
      "text": "#36 SOURCE: Massena Observer Oct. 4",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 18,
      "text": "OCT. 6, 1951 Daytime. LODI, Ohio. 41° [REDACTED] 82° Longitude.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 19,
      "text": "An object resembling a barrel and making a hissing noise",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 20,
      "text": "crossed sky at great height with [REDACTED] speed greater than",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 21,
      "text": "any aircraft. During its course, it stopped without",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 22,
      "text": "slowing and made a right angle turn, and sped northward.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 23,
      "text": "#37 SOURCE: Indiana Star Oct 11",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 24,
      "text": "OCT. 9, 1951 1:42 PM. TERRE HAUTE, Indiana. 39½° Latitude, 87½° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 25,
      "text": "A round or oval-shaped, whitish-metallic ball crossed sky",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 26,
      "text": "from horizon to horizon at a speed estimated between 5,000",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 27,
      "text": "mph and 42,000 mph. Seen by 2 CAA observers with 10 and",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 28,
      "text": "16 years of aircraft observation respectively. Both",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 29,
      "text": "stated it could not have been a balloon.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 30,
      "text": "#38 SOURCE: Terre Haute Tribune Oct 11; Terre Haute Star Oct11",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 31,
      "text": "OCT 9, 1951 2:10 to 2:20 PM. PARIS, Illinois. 39½° Lrt, 88° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 32,
      "text": "Wind speed 10 mph. A brilliant white, round object hovering",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 33,
      "text": "in air for 10 minutes, while a private airplane tried to",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 34,
      "text": "approach it, but apparently came no closer. It then sped",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 35,
      "text": "off.",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "#39 SOURCE: Terre Haute Tribune Oct 11",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 37,
      "text": "OCT. 9, 1951 6:30 PM. Near INDIANAPOLIS, Indiana. 39° Lat, 86° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 38,
      "text": "A whitish ball-like object crossed sky at great speed,",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 39,
      "text": "rose almost vertically, hung motionless in sky for a second",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 40,
      "text": "and then sped off.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 41,
      "text": "#40 SOURCE: Indiana Star Oct 11",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 42,
      "text": "OCT. 15 1951 2:30 PM. DENVER, Colorado. 39½° Lat., 105° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 43,
      "text": "A fiery ball fell from sky and landed near a child. It was",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 44,
      "text": "a 45# block of material of unknown origin, and examination",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 45,
      "text": "by an astronomer, Dr. Fath, resulted in its classification",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 46,
      "text": "as not like any known meteoric stone.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 47,
      "text": "#41 SOURCE: NY World Telegram & Sun Oct 18; Denver Post Oct18,1",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 48,
      "text": "OCTOBER 1951 Daytime. CODY, Wyoming. 44½° Lrt., 109° Long.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 49,
      "text": "Clear sky, nothing in flight. A photograph was taken of",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 50,
      "text": "nearby land and mountains by [unclear] couple. Upon",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    }
  ],
