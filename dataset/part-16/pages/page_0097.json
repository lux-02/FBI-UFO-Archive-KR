    {
      "lineNumber": 10,
      "text": "At 6:30 A. M. this date, Mr. [REDACTED] telephonically",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 11,
      "text": "contacted this office, and advised that he had found a strange",
