    },
    {
      "lineNumber": 23,
      "text": "speech and thickness of tongue, he was under the influence of liquor.",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "status": "blank"
    },
    {
      "lineNumber": 25,
      "text": "Mr. [REDACTED] called again at 7:00 A.M. and he was again",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
