      "status": "pending_image_audit"
    },
    {
      "lineNumber": 23,
      "text": "Winterrowd",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 24,
      "text": "Tele. Room",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 25,
