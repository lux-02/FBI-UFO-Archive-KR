      "status": "blank"
    },
    {
      "lineNumber": 9,
      "text": "SUBJECT: UNIDENTIFIED FLYING OBJECT REPORTED",
      "status": "image_matched"
    },
    {
      "lineNumber": 10,
      "text": "ON SEPTEMBER 20, 1957; INTELLIGENCE",
      "status": "image_matched"
    },
    {
      "lineNumber": 11,
      "text": "ADVISORY COMMITTEE - WATCH COMMITTEE",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "status": "blank"
    },
    {
