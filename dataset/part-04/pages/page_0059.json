      "lineNumber": 20,
      "text": "and diving at scout camps and the municipal pool in Minot, North Dakota.",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 21,
      "text": "I went to the University of Minnesota, where I swam and did fancy diving",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 22,
      "text": "under [REDACTED], and also played football under [REDACTED], but",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
