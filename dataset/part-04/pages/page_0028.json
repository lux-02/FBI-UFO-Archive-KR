      "text": "the combustion of the lava oxide metal it carried.",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "status": "blank"
    },
    {
      "lineNumber": 23,
      "text": "From the above newspaper article, it should be noted that [REDACTED]",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
