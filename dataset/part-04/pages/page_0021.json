      "status": "image_matched"
    },
    {
      "lineNumber": 5,
      "text": "Mitchel Field, New York",
      "status": "image_matched"
    },
    {
      "lineNumber": 6,
      "status": "blank"
    },
    {
      "lineNumber": 7,
      "text": "In reply",
      "status": "image_matched"
    },
    {
      "lineNumber": 8,
      "text": "refer to:",
      "status": "permanent_unresolved",
