      "text": "TO : Director, FBI",
      "status": "image_matched"
    },
    {
      "lineNumber": 5,
      "text": "DATE: September 20, 1947",
      "status": "image_matched"
    },
    {
      "lineNumber": 6,
      "status": "blank"
    },
    {
      "lineNumber": 7,
      "text": "FROM : SAC, Chicago",
