    {
      "lineNumber": 20,
      "text": "L. R. BRUMMETT. SID DECKER. FLYING DISCS. INTERNAL SCURITY - X",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 21,
      "status": "blank"
    },
    {
      "lineNumber": 22,
      "text": "AUGUST FOURTEEN NINETEEN FORTYSEVEN SEATTLE POST INTELLIGENCER",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 23,
      "text": "PUBLISHED ARTICLE TO EFFECT THAT L. R. BRUMMETT, BOX TWO FIVE FOUR RED-",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "MOND, WASH, AND SIDNEY DECKER BOX TWO NINE SIX REDMOND, WASHINGTON HAD",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "SIGHTED TWO DISCS AT APPROXIMATELY NINE AM AUGUST THIRTEEN NINETEEN",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "FORTYSEVEN. UPON INTERVIEW DECKER STATED THAT TWO VERY BRIGHT OJECTS",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 27,
      "text": "TRAVELING AT AN EXTREME RATE OF SPEED WERE NOTICED BY HIM AS HE WAS",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "STANDING NEAR THE REDMOND POST OFFICE. DECKER DESCRIBED THE OBJECTS",
      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "text": "AS HAVING NO WINGS, NO TAIL, AND BOTH ENDS WERE TAPERED. DECKER ADDED",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "THAT THE OBJECTS RESEMBLED A BELLY TANK AND THAT THEY WERE NOISELESS.",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "THE OBJECTS WERE VERY BRIGHT AND TRAVELING IN A NORTHEASTERLY DIRECTION",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "text": "OVER REDMOND, WASHINGTON, ONE A BIT BEHIND AND A LITTLE ABOVE THE OTHER",
      "status": "image_matched"
    },
    {
      "lineNumber": 33,
      "text": "MAINTAINING EQUAL RATES OF SPEED FOR APPROXIMATELY EIGHT SECONDS AT",
      "status": "image_matched"
    },
    {
      "lineNumber": 34,
      "text": "WHICH TIME THEY DISAPPEARED FROM VIEW. DECKER ADDED THAT THEY WERE",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "HIGHER THAN A PLANE GENERALLY TRAVELS. BRUMMETT ADVISED THAT HE NOTICED",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "THE OBJECTS AND CALLED DECKERS ATTENTION TO THEM AND ALSO POINTED THEM",
      "status": "image_matched"
    },
    {
      "lineNumber": 37,
      "text": "OUT TO A MRS MAMIE ENGLISH. BRUMMETT STATED THAT HE SAW TWO OBJECTS",
      "status": "image_matched"
    },
    {
