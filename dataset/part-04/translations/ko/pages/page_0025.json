        ],
        "refs": [
          {
            "part": 4,
            "page": 25,
            "pageId": "page_0025",
            "lineId": "page_0025-l0016",
            "lineNumber": 16,
            "sourcePath": "docs/ufo4.pdf",
            "sourceSha256": "ccb69dd730f65e8369ab6a82ae48c14c36c06ce9abb9e62e9962cf102d7b4847"
          }
        ],
        "text": "Both officers attempted to determine the approximate altitude of the object, and from a weather group stationed nearby it was determined that cloud formations at the time the object was sighted were \"scattered above 10,000 feet.\" The object was noted to be traveling below the cloud formation."
      },
      "translation": {
        "text": "두 장교는 물체의 대략적인 고도를 파악하려고 시도했으며, 근처에 주둔한 기상반으로부터 물체가 목격되었을 당시의 구름 형성은 \"10,000피트 상공에 흩어져 있었음\"이 확인되었습니다. 그 물체는 구름 형성 아래로 이동하는 것이 관찰되었습니다.",
        "reviewedAt": "2026-05-10T08:59:17.322Z",
        "reviewer": "codex",
        "reviewMethod": "Gemini first draft with Codex source-faithfulness review",
        "draftProvider": "gemini_api",
        "draftModel": "gemini-2.5-pro",
        "promptVersion": "gemini3_ko_translation_draft_v1",
        "overrideApplied": false,
        "overrideReason": null
      }
    },
    {
      "id": "TU-p04-page-0025-u008",
      "unitVersion": 1,
      "part": 4,
      "page": 25,
      "pageId": "page_0025",
      "status": "reviewed",
      "approvalStatus": "not_approved",
      "language": "ko",
      "source": {
        "path": "docs/ufo4.pdf",
        "sha256": "ccb69dd730f65e8369ab6a82ae48c14c36c06ce9abb9e62e9962cf102d7b4847",
        "lineIds": [
