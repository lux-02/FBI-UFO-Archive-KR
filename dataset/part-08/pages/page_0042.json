    {
      "lineNumber": 31,
      "text": "FLYING SAUCERS. TWO SOURCES ADVISED TODAY THAT UNIDENTIFIED INDIVIDUAL",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 32,
      "text": "HAS GIVEN AT LEAST ONE AND POSSIBLY MORE LECTURES BEFORE CLASSES AT",
      "status": "image_matched"
    },
    {
      "lineNumber": 33,
      "text": "DENVER UNIVERSITY YESTERDAY OR TODAY IN WHICH HE DISCUSSED FLYING",
      "status": "image_matched"
    },
    {
      "lineNumber": 34,
      "text": "SAUCERS WHICH HE ALLEGEDLY PERSONALLY OBSERVED. THIS PERSON CLAIMS TO",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "HAVE SEEN SEVERAL SUCH OBJECTS, ONE OF WHICH ALLEGEDLY LANDED IN NEW",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "MEXICO. HE ALSO CLAIMS TO HAVE OBSERVED OCCUPANTS OF SAUCERS DESCRIBED",
      "status": "image_matched"
    },
    {
      "lineNumber": 37,
      "text": "BY HIM AS OF HUMAN FORM, BUT ABOUT THREE FEET TALL. THESE OCCUPANTS OF",
      "status": "image_matched"
    },
    {
      "lineNumber": 38,
      "text": "SAUCERS ALLEGEDLY DEAD AT TIME HE OBSERVED THEM. THIS LECTURER [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 39,
      "text": "REFUSED TO REVEAL IDENTITY, BUT IS KNOWN TO [REDACTED] WHO IS",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 40,
      "text": "[REDACTED] CONNECTED WITH [REDACTED] DENVER. [REDACTED] REPORTED",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 41,
      "text": "TO HAVE MADE SOME PREVIOUS CLAIMS HIMSELF WITH RESPECT TO OBSERVING",
      "status": "image_matched"
    },
    {
      "lineNumber": 42,
      "text": "FLYING SAUCERS. LOCAL PRESS AND ALSO WIRE SERVICES CARRYING STORIES",
      "status": "image_matched"
    },
    {
      "lineNumber": 43,
      "text": "CONCERNING THESE LECTURES AT DENVER UNIVERSITY. OSI, DENVER, HAS NO",
      "status": "image_matched"
    },
    {
      "lineNumber": 44,
      "text": "ADDITIONAL INFORMATION EXCEPT THAT [REDACTED] IN JANUARY THIS",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 45,
      "text": "YEAR REPORTED TO HAVE MADE SIMILAR CLAIMS AND UPON INVESTIGATION WAS",
      "status": "image_matched"
    },
    {
      "lineNumber": 46,
      "text": "UNABLE TO PRODUCE ANY VERIFIABLE INFORMATION. OSI CONSIDERS [REDACTED] AS",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 47,
      "text": "PROBABLE MENTAL CASE. BUREAU ADVISE WHAT, IF ANY, ACTION DESIRED AT",
      "status": "image_matched"
