    {
      "lineNumber": 25,
      "status": "blank"
    },
    {
      "lineNumber": 26,
      "text": "UNKNOWN OBJECT OVER OAK RIDGE, TENN., MARCH ONE, NINETEEN FIFTY",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "COMPLAINANT, VITAL FACILITIES, IS. REMYCALL",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "status": "blank"
    },
    {
      "lineNumber": 29,
      "text": "MARCH THIRD. EXISTENCE OF OBJECT REPORTED BY [REDACTED] AS BEING",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 30,
      "text": "DIRECTLY OVER OAK RIDGE AT ONE HUNDRED THOUSAND FEET ALTITUDE NOT",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "VERIFIED.",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "text": "REPUTEDLY,CAPABLE RADIO TECHNICIAN. [REDACTED] CLAIMS",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 33,
      "text": "TO HAVE DETECTED OBJECT WITH HIS RADAR EQUIPMENT. ON FIVE OCCASIONS",
      "status": "image_matched"
    },
    {
      "lineNumber": 34,
      "text": "OVER THREE DAYS. NAVAL RESERVE RADAR EQUIPMENT AT KNOXVILLE DID NOT",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "DETECT OBJECT ON ANY OCCASION, BUT TECHNICIANS STATE IT IS NOT",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "CONSIDERED EFFICIENT FOR AIRCRAFT AT EXTREME ALTITUDES. QUALIFIED",
      "status": "image_matched"
    },
    {
      "lineNumber": 37,
      "text": "PERSONS FROM USAF AT NEPA, OAK RIDGE, TALKED WITH [REDACTED] AND",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 38,
      "text": "EXAMINED HIS RADAR EQUIPMENT. FOUND HIS EQUIPMENT NOT TOO RELIABLE",
      "status": "image_matched"
    },
    {
      "lineNumber": 39,
      "text": "AND FELT [REDACTED] TECHNICALLY WRONG ON SOME RADAR THEORY. RELIABILITY",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 40,
      "text": "OF [REDACTED] QUESTIONED DUE TO SOME DEGREE OF INEBRIATION. THESE",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 41,
      "text": "PERSONS DISCOUNT PROBABILITY. ICIC AND OSI CONTINUE INTEREST BUT",
      "status": "image_matched"
    },
    {
      "lineNumber": 42,
      "text": "DO NOT CONTEMPLATE FURTHER ACTION. AEC TOOK STEPS TO HAVE RADAR",
      "status": "image_matched"
    },
    {
      "lineNumber": 43,
      "text": "TECHNICIAN SENT FROM WASH., BELIEVED FROM CIA BUT NOT YET ARRIVED.",
      "status": "image_matched"
    },
    {
      "lineNumber": 44,
      "text": "ANY FURTHER DEVELOPMENTS WILL BE REPORTED TO BUREAU.",
      "status": "image_matched"
    },
