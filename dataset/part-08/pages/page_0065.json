    {
      "lineNumber": 11,
      "text": "DATE: July 26, 1949",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "text": "On July 15, 1949, the Office of the Assistant Chief of Staff,",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "G-2, Fourth Army, advised that a small article which had appeared in the",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "Galveston (Texas) News on July 10, 1949, advertised the fact that the",
      "status": "image_matched"
    },
    {
      "lineNumber": 15,
      "text": "Young Men's Business Club of Alexandria, Louisiana, announced that it was",
      "status": "image_matched"
    },
    {
      "lineNumber": 16,
      "text": "planning a convention for persons from all over the nation who have seen",
      "status": "image_matched"
    },
    {
      "lineNumber": 17,
      "text": "flying saucers. It was stated that the convention was planned so that members",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "text": "may compare notes. It was also stated that flying disks were reported twice",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "text": "in the week preceding the article in Alexandria, Louisiana.",
      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "The above is furnished as a matter of information.",
      "status": "image_matched"
