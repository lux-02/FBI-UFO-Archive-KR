      "status": "image_matched"
    },
    {
      "lineNumber": 7,
      "status": "blank"
    },
    {
      "lineNumber": 8,
      "text": "Mr. J. Edgar Hoover",
      "status": "image_matched"
    },
    {
      "lineNumber": 9,
      "text": "Director",
      "status": "image_matched"
    },
    {
