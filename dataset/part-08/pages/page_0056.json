    },
    {
      "lineNumber": 6,
      "text": "Your letter dated October 6, 1949, has been received",
      "status": "image_matched"
    },
    {
      "lineNumber": 7,
      "text": "and in response to your request I am returning it to you at this",
      "status": "image_matched"
    },
    {
      "lineNumber": 8,
      "text": "time.",
      "status": "image_matched"
    },
    {
      "lineNumber": 9,
      "text": "For your information the jurisdiction of this Bureau",
      "status": "image_matched"
    },
    {
