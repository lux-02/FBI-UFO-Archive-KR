      "text": "the Division of International Press and Publications, Office of",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "Public Affairs, United States Department of State, 21st Street",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "text": "and Virginia Avenue, Washington, D. C., with regard to the",
      "status": "image_matched"
    },
    {
