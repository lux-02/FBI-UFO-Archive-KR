    {
      "lineNumber": 23,
      "text": "Subject: FLYING DISC OBSERVED",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "OXFORD, PENNSYLVANIA",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "MAY 4, 1956",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "MISCELLANEOUS - INFORMATION CONCERNING (ESPIONAGE)",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "At 11:35 p.m., May 4, 1956, an individual",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "who identified himself as [REDACTED]",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 29,
      "text": "Oxford, Pennsylvania, advised this Bureau",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "he had just observed at Oxford, Pennsylvania, a",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "bright light traveling about 2,000 feet in the air",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "text": "toward Baltimore, Maryland. He described the object",
      "status": "image_matched"
    },
    {
      "lineNumber": 33,
      "text": "as a solid, bright yellow light visible from all",
      "status": "image_matched"
    },
    {
      "lineNumber": 34,
      "text": "directions and that it was twice as bright and twice",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "as large as the headlight of an automobile. He also",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "described it as twice as bright as the evening star.",
      "status": "image_matched"
    },
    {
      "lineNumber": 37,
      "text": "He was unable to described it in more detail. He",
      "status": "image_matched"
    },
    {
      "lineNumber": 38,
      "text": "stated the object made no noise, that at first its",
      "status": "image_matched"
    },
    {
      "lineNumber": 39,
      "text": "speed was the same as the car he was driving but it",
      "status": "image_matched"
    },
    {
      "lineNumber": 40,
      "text": "sped up and although he was driving 80 miles an hour",
      "status": "image_matched"
    },
    {
      "lineNumber": 41,
      "text": "he was unable to keep up with it. He advised that",
      "status": "image_matched"
    },
    {
      "lineNumber": 42,
      "text": "two of his friends, [REDACTED] also",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 43,
      "text": "had observed the object.",
      "status": "image_matched"
    },
    {
      "lineNumber": 44,
      "text": "BY COURIER SVC.",
      "status": "image_matched"
    },
    {
      "lineNumber": 45,
      "text": "42 MAY 14",
      "status": "image_matched"
    },
