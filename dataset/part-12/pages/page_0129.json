    },
    {
      "lineNumber": 13,
      "status": "blank"
    },
    {
      "lineNumber": 14,
      "text": "Jesus' ascension is described as \"a cloud (or space-ship) received Him",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
