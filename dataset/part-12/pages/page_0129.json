      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 46,
      "text": "tors put it, \"stopping-places\", \"resting-stations\" or \"filling-stations",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
