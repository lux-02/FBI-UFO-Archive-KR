      "text": "mation was accepted for transmittal to the appropriate",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "text": "agency, which was to contact you if interested.",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "status": "blank"
    },
    {
      "lineNumber": 20,
      "text": "Full details were made available at that time to",
      "status": "image_matched"
    },
    {
      "lineNumber": 21,
      "text": "the Department of the Air Force for evaluation and consider-",
      "status": "image_matched"
