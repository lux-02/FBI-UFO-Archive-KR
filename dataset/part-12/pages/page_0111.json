    {
      "lineNumber": 15,
      "text": "UP73",
      "status": "image_matched"
    },
    {
      "lineNumber": 16,
      "text": "(FLYING SAUCERS)",
      "status": "image_matched"
    },
    {
      "lineNumber": 17,
      "text": "THE DIRECTOR OF THE GOVERNMENT'S TOP AIR RESEARCH AGENCY HAS TOLD",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "text": "CONGRESS FLATLY THAT THERE IS NO SUCH THING AS A FLYING SAUCER.",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "text": "THE ASSURANCE CAME FROM DR. HUGH L. DRYDEN, DIRECTOR OF THE NATIONAL",
      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "ADVISORY COMMITTEE FOR AERONAUTICS, AT A CLOSED-DOOR HEARING BY A HOUSE",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 21,
      "text": "APPROPRIATIONS SUBCOMMITTEE.",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "THE TESTIMONY, TAKEN ON FEB. 19, WAS MADE PUBLIC TODAY.",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "DRYDEN AND OTHER NACA OFFICIALS, INCLUDING GEN. JAMES A. DOOLITTLE,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 24,
      "text": "THE AGENCY CHAIRMAN WERE QUESTIONED ABOUT A REPORT PUBLISHED IN",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "GERMANY THAT THE NAZIS DEVELOPED SHORTLY BEFORE THE END OF WORLD WAR",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "II A 138-FOOT SAUCER THAT ROSE TO 40,000 FEET AND FLEW AT A SPEED OF",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "1,250 MILES AN HOUR.",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "\"THERE IS NO TRUTH IN THAT STATEMENT,\" DRYDEN SAID. \"THIS IS AN",
      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "text": "ADVERTISEMENT FOR A BOOK...\"",
      "status": "image_matched"
    },
    {
      "lineNumber": 30,
      "text": "REP. ALBERT THOMAS (D-TEX.), SUBCOMMITTEE CHAIRMAN, PRESSING FOR A",
      "status": "image_matched"
    },
    {
      "lineNumber": 31,
      "text": "MORE CONCLUSIVE STATEMENT, ASKED:",
      "status": "image_matched"
    },
    {
      "lineNumber": 32,
      "text": "\"IS THERE NO SUCH THING AS A FLYING SAUCER, AND THE GERMANS",
      "status": "image_matched"
    },
    {
      "lineNumber": 33,
      "text": "DIDN'T HAVE IT IN 1945 AND DON'T HAVE IT YET?\"",
      "status": "image_matched"
    },
    {
      "lineNumber": 34,
      "text": "\"THAT IS RIGHT,\" SAID DRYDEN.",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "DRYDEN ALSO DENIED A RELATED CLAIM THAT THE NAZIS HAD PERFECTED A",
      "status": "image_matched"
    },
    {
      "lineNumber": 36,
      "text": "BOMBER THAT COULD HIT THE U.S. AND RETURN WITHOUT REFUELING.",
      "status": "image_matched"
    },
    {
      "lineNumber": 37,
      "text": "\"YOU HAVE TO DISTINGUISH HARDWARE FROM IDEAS,\" DRYDEN EXPLAINED.",
      "status": "image_matched"
    },
