    {
      "lineNumber": 16,
      "text": "ADD 1 FLYING SAUCERS",
      "status": "image_matched"
    },
    {
      "lineNumber": 17,
      "text": "DOOLITTLE ALSO DISCOUNTED THE PUBLISHED ACCOUNT OF THE SAUCER AND",
      "status": "image_matched"
    },
    {
      "lineNumber": 18,
      "text": "INTERCONTINENTAL BOMBER, WARNING HOWEVER THAT BACKERS OF THE BOOK",
      "status": "image_matched"
    },
    {
      "lineNumber": 19,
      "text": "PROBABLY WOULD USE THE DENIALS AS ANOTHER \"LEG UP\" TO PUBLICIZE IT.",
      "status": "image_matched"
    },
    {
      "lineNumber": 20,
      "text": "IN REFERENCE TO FREQUENTLY PUBLISHED \"SIGHTINGS\" OF WHAT OFFICIALLY",
      "status": "image_matched"
    },
    {
      "lineNumber": 21,
      "text": "ARE CALLED \"UNIDENTIFIED FLYING OBJECTS\" THOMAS SAID THE AIR FORCE, OR",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "SOME OTHER AUTHORITY, \"OUGHT TO, ONCE AND FOR ALL, NAIL IT DOWN AND SAY",
      "status": "image_matched"
    },
    {
      "lineNumber": 23,
      "text": "IT IS PURE FICTION.\"",
      "status": "image_matched"
    },
    {
      "lineNumber": 24,
      "text": "HE SAID THE AIR FORCE HAD \"HEMMED AND HAWED\" ON THE ISSUE, APPARENTLY",
      "status": "image_matched"
    },
    {
      "lineNumber": 25,
      "text": "A REFERENCE TO THE 1955 AIR FORCE REPORT THAT IT HAD INVESTIGATED 5,000",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "REPORTED SIGHTINGS AND FOUND \"NO EVIDENCE\" OF THE EXISTENCE OF",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "SAUCERS.",
      "status": "image_matched"
    },
    {
      "lineNumber": 28,
      "text": "THIS WASN'T QUITE THE SAME THING AS SAYING THE SAUCERS DID NOT",
      "status": "image_matched"
    },
    {
      "lineNumber": 29,
      "text": "EXIST, AS DRYDEN NOW HAS ASSERTED.",
      "status": "image_matched"
    },
