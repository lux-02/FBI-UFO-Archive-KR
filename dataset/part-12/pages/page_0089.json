    },
    {
      "lineNumber": 18,
      "text": "yards in diameter, and about 14 feet high, consisting of",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 19,
      "text": "dark gray stationary top and bottom sections, five to six",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 20,
      "text": "feet high. The approximate three foot middle section appeared",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 21,
      "text": "to be a rapidly moving component producing a continuous blur",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 22,
      "text": "similar to an aeroplane propeller, but extending the cir-",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
