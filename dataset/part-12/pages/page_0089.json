      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 11,
      "text": "was observed to slowly rise vertically to a height sufficient",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 12,
      "text": "to clear the wall and then to move slowly horizontally a",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 13,
      "text": "short distance out of his view, which was obstructed by",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 14,
      "text": "nearby trees.",
