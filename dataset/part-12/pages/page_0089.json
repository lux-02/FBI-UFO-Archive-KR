      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 15,
      "status": "blank"
    },
    {
      "lineNumber": 16,
      "text": "This vehicle, observed from approximately",
      "status": "permanent_unresolved",
      "unresolvedReason": "other_documented"
    },
    {
      "lineNumber": 17,
      "text": "500 feet, was described as circular in shape, 75 to 100",
      "status": "permanent_unresolved",
