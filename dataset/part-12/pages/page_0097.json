    },
    {
      "lineNumber": 34,
      "text": "REPORT OF SIGHTING OF UNKNOWN FLYING OBJECT NEAR DANVILLE,",
      "status": "image_matched"
    },
    {
      "lineNumber": 35,
      "text": "ILLINOIS, NOVEMBER 6, 1957. INFORMATION CONCERNING, [REDACTED] REPORTED THAT",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 36,
      "text": "[REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 37,
      "text": "REPORTED AT APPROXIMATELY 9:00 PM, NOVEMBER 7, 1957, SIGHTING",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 38,
      "text": "A BRIGHT WHITE LIGHT FLYING THROUGH THE AIR IN A SOUTHWESTERLY",
      "status": "image_matched"
    },
    {
      "lineNumber": 39,
      "text": "DIRECTION FROM DANVILLE, ILLINOIS. [REDACTED] TRIED TO FOLLOW",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 40,
      "text": "IN THEIR CAR IN THE SAME DIRECTION AND DROVE GENERALLY IN A",
      "status": "image_matched"
    },
    {
      "lineNumber": 41,
      "text": "SOUTHWESTERLY DIRECTION FOR TWENTY MILES WHEN THEY LOST SIGHT",
      "status": "image_matched"
    },
    {
      "lineNumber": 42,
      "text": "OF THE OBJECT. DURING THIS TIME IT APPEARED AS BRIGHT-WHITE,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 43,
      "text": "AMBER AND ORANGE. NO INDICATION THAT IT DIPPED TO THE GROUND",
      "status": "image_matched"
    },
    {
      "lineNumber": 44,
      "text": "OR THAT IT AFFECTED THEIR CAR. THEY REPORTED FOR A FEW SECONDS",
      "status": "image_matched"
    },
    {
      "lineNumber": 45,
      "text": "IT SEEMED TO AFFECT BOTH THE RECEIVER AND TRANSMITTER OF THEIR",
      "status": "image_matched"
    },
    {
      "lineNumber": 46,
      "text": "FM TWO-WAY RADIO. REPRESENTATIVES OF INTERNATIONAL NEWS SERVICE",
      "status": "image_matched"
    },
    {
      "lineNumber": 47,
      "text": "INQUIRED THIS OFFICE CONCERNING, NO COMMENT WAS MADE. ABOVE",
      "status": "image_matched"
    },
    {
      "lineNumber": 48,
      "text": "BEING FURNISHED FOR INFORMATION BUREAU.",
      "status": "image_matched"
    },
