    },
    {
      "lineNumber": 9,
      "status": "blank"
    },
    {
      "lineNumber": 10,
      "text": "PURPOSE:",
      "status": "image_matched"
    },
    {
      "lineNumber": 11,
      "text": "To advise all Supervisors engaged on night",
      "status": "image_matched"
    },
    {
      "lineNumber": 12,
      "text": "duty of instructions concerning the referral of",
      "status": "image_matched"
    },
    {
      "lineNumber": 13,
      "text": "flying disc information to OSI.",
      "status": "image_matched"
    },
    {
      "lineNumber": 14,
      "status": "blank"
    },
    {
      "lineNumber": 15,
      "text": "BACKGROUND:",
      "status": "image_matched"
    },
    {
      "lineNumber": 16,
      "text": "Captain [REDACTED] OSI, 4th Air Force",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 17,
      "text": "Base, Bowling Field, has requested that any information",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 18,
      "text": "concerning the sighting of flying discs (saucers, etc.)",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 19,
      "text": "be telephonically furnished immediately to his office,",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 20,
      "text": "day or night, by dialling Code 1261, and asking for",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 21,
      "text": "Extension 509. Captain [REDACTED] advised the Air Force",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 22,
      "text": "is greatly concerned about the captioned matter, and",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 23,
      "text": "would appreciate the Bureau's cooperation in immediately",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 24,
      "text": "advising of details received concerning such complaints.",
      "status": "pending_image_audit"
    },
    {
      "lineNumber": 25,
      "status": "blank"
    },
    {
      "lineNumber": 26,
      "text": "ACTION:",
      "status": "image_matched"
    },
    {
