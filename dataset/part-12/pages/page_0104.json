    {
      "lineNumber": 20,
      "status": "blank"
    },
    {
      "lineNumber": 21,
      "text": "For the information of the Bureau and the Norfolk Office,",
      "status": "image_matched"
    },
    {
      "lineNumber": 22,
      "text": "Mr. [REDACTED] is presently the Advertising Manager for [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 23,
      "text": "[REDACTED] Cincinnati, Ohio. According",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 24,
      "text": "to [REDACTED] he has been interested in flying discs or objects",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 25,
      "text": "for a number of years and has cooperated with the United States",
      "status": "image_matched"
    },
    {
      "lineNumber": 26,
      "text": "Air Force to the extent of furnishing the Air Force with any",
      "status": "image_matched"
    },
    {
      "lineNumber": 27,
      "text": "information on flying objects coming to his attention. Mr. [REDACTED]",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 28,
      "text": "[REDACTED] was also the publisher of a paper called the [REDACTED]\", which",
      "status": "redaction_marker_check"
    },
    {
      "lineNumber": 29,
      "text": "carried the following heading: [REDACTED]",
