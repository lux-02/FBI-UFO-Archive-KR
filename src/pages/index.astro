---
import Layout from "@/components/Layout.astro";
import { getPublishedDatasetParts } from "@/lib/public-dataset";

const parts = getPublishedDatasetParts();
const readerPartCount = parts.filter((part) => part.hasReader).length;
const readerRangeLabel = readerPartCount > 0 ? `Part 01-${String(readerPartCount).padStart(2, "0")}` : "공개 대기";
---

<Layout title="아카이브">
  <section class="archive-frame mb-6 p-5">
    <div class="mb-3 flex flex-wrap items-center gap-2">
      <span class="lcd-label">PUBLIC VAULT TERMINAL</span>
      <span class="source-label">{readerRangeLabel} 열람 가능</span>
    </div>
    <div>
      <h1 class="terminal-title mb-3 text-4xl font-semibold leading-tight sm:text-6xl">
        PUBLIC VAULT<br />TERMINAL
      </h1>
      <p class="max-w-prose text-sm leading-7 text-[var(--color-text-secondary)]">
        FBI Vault UFO PDF 16편을 원본 스캔과 한국어 복원본으로 읽습니다.
      </p>
    </div>
  </section>

  <section
    class="grid gap-3 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
  >
    {
      parts.map((p) => {
        const translatedPages = p.translationSummary?.counts.pageCount ?? 0;
        const translatedPercent =
          p.source.pageCount > 0 ? Math.round((translatedPages / p.source.pageCount) * 100) : 0;
        const restoreLabel =
          translatedPercent >= 100
            ? "복원 완료"
            : translatedPages > 0
              ? "일부 복원"
              : "원본";
        const href = p.hasReader ? `/archive/${p.slug}` : p.source.viewUrl;
        return (
          <a
            href={href}
            target={p.hasReader ? undefined : "_blank"}
            rel={p.hasReader ? undefined : "noopener noreferrer"}
            class:list={[
              "dossier-card block p-4 transition-colors",
              p.hasReader ? "" : "dossier-card--pending",
            ]}
          >
            {
              translatedPages === 0 ? (
                <span
                  class="dossier-lock"
                  role="img"
                  aria-label="한국어 복원 대기"
                  title="한국어 복원 대기"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <rect x="4" y="10" width="16" height="10" />
                    <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                  </svg>
                </span>
              ) : null
            }
            <div class="mb-3 flex items-start justify-between gap-3">
              <div>
                <div class="terminal-index">FILE {p.partLabel}</div>
                <div class="terminal-title text-lg text-[var(--color-text-primary)]">UFO PART {p.partLabel}</div>
              </div>
              <span class:list={[
                "dossier-status-label",
                translatedPages > 0 ? "source-label" : "hold-label",
              ]}>
                {restoreLabel}
              </span>
            </div>
            <div class="terminal-rule mb-3"></div>
            <div class="space-y-1 text-xs text-[var(--color-text-muted)]">
              <div class="terminal-data-line">
                <span>복원</span>
                <span>{translatedPercent}%</span>
              </div>
            </div>
            <div class="progress-track mt-4 h-1.5">
              <div
                class:list={["progress-fill", p.hasReader ? "" : "progress-fill--pending"]}
                style={`width: ${translatedPercent}%`}
              />
            </div>
            <p class="mt-2 font-mono text-[0.68rem] leading-5 text-[var(--color-text-muted)]">
              {translatedPages > 0 ? `한국어 ${translatedPages}쪽` : "한국어 미제공"} / 원본 {p.source.pageCount}쪽
            </p>
          </a>
        );
      })
    }
  </section>
</Layout>
