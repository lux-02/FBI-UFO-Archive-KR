---
interface Props {
  partSlug: string;
  maxPage: number;
  currentPage?: number | undefined;
}

const { partSlug, maxPage, currentPage } = Astro.props;
const currentValue = currentPage ? String(currentPage) : "";
---

<form class="page-jump-form" data-page-jump data-part-slug={partSlug} data-max-page={maxPage}>
  <label class="page-jump-field">
    <span class="sr-only">페이지 이동</span>
    <input
      name="page"
      type="text"
      inputmode="numeric"
      pattern="[0-9]{1,4}"
      maxlength="4"
      value={currentValue}
      placeholder="1"
      aria-label="페이지 번호"
      class="page-jump-input"
    />
    <span class="page-jump-suffix" aria-hidden="true">p</span>
  </label>
  <button type="submit" class="page-jump-button" aria-label="입력한 페이지로 이동">GO</button>
</form>

<script>
  function clampPageInput(input: HTMLInputElement, maxPage: number): void {
    const digits = input.value.replace(/\D/g, "").slice(0, 4);
    if (!digits) {
      input.value = "";
      return;
    }
    const requested = Number(digits);
    if (!Number.isInteger(requested) || requested < 1) {
      input.value = "";
      return;
    }
    input.value = String(Math.min(requested, maxPage));
  }

  for (const form of document.querySelectorAll("[data-page-jump]")) {
    if (!(form instanceof HTMLFormElement) || form.dataset.bound === "true") continue;
    form.dataset.bound = "true";
    const input = form.querySelector("input[name='page']");
    const maxPage = Number(form.dataset.maxPage ?? "0");

    input?.addEventListener("input", () => {
      if (!(input instanceof HTMLInputElement) || maxPage < 1) return;
      clampPageInput(input, maxPage);
    });

    input?.addEventListener("focus", () => {
      if (!(input instanceof HTMLInputElement)) return;
      input.select();
    });

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const partSlug = form.dataset.partSlug ?? "";
      if (!(input instanceof HTMLInputElement) || !partSlug || maxPage < 1) return;
      const requested = Number(input.value.replace(/\D/g, ""));
      if (!Number.isInteger(requested) || requested < 1) return;
      const page = Math.min(Math.max(requested, 1), maxPage);
      window.location.href = `/archive/${partSlug}/page-${String(page).padStart(4, "0")}`;
    });
  }
</script>
